{
  "name": "ralph-loop-harness",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "loop": "node --import tsx src/ralph-loop.ts",
    "once": "npm run loop -- once",
    "loop:status": "npm run loop -- status",
    "loop:run": "npm run loop -- run",
    "loop:run:task": "npm run loop -- once",
    "typecheck": "tsc --noEmit",
    "api:dev": "npm run dev --workspace @ralph/api",
    "api:typecheck": "npm run typecheck --workspace @ralph/api",
    "api:build": "npm run build --workspace @ralph/api",
    "api:start": "npm run start --workspace @ralph/api",
    "web:dev": "npm run dev --workspace @ralph/web",
    "web:typecheck": "npm run typecheck --workspace @ralph/web",
    "web:build": "npm run build --workspace @ralph/web",
    "web:start": "npm run start --workspace @ralph/web",
    "smoke:deploy": "node scripts/deploy-smoke.mjs",
    "app:typecheck": "tsc --noEmit -p tsconfig.app.json",
    "app:build": "tsc -p tsconfig.app.json",
    "app:health": "node --import tsx src/app/health.ts",
    "app:start": "node --import tsx src/app/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "js-yaml": "^4.1.0",
    "next": "^15.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3"
  }
}
