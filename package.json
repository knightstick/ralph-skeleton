{
  "name": "ralph-loop-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "loop": "node --import tsx src/ralph-loop.ts",
    "once": "npm run loop -- run",
    "loop:status": "npm run loop -- status",
    "loop:run": "npm run loop -- run",
    "loop:run:task": "npm run loop -- run",
    "typecheck": "tsc --noEmit",
    "app:typecheck": "tsc --noEmit -p tsconfig.app.json",
    "app:build": "tsc -p tsconfig.app.json",
    "app:start": "node --import tsx src/app/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.3"
  }
}
