{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "npm run api:build",
    "watchPatterns": [
      "apps/api/**",
      "package.json",
      "package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run api:start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
